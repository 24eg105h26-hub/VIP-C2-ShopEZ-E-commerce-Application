{
  "info": {
    "_postman_id": "shopez-api-collection-2026",
    "name": "shopEZ API Collection",
    "description": "Production API endpoints for shopEZ Customer, Seller, and Admin portals.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Johnson\",\n  \"email\": \"customer@shopez.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@shopez.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Token Refresh",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/auth/refresh",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Log Out",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/auth/logout",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Customer Catalog",
      "item": [
        {
          "name": "Get Products (Paginated & Filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/products?category=electronics&minPrice=100&sort=price-asc",
              "host": ["{{BASE_URL}}"],
              "path": ["products"],
              "query": [
                { "key": "category", "value": "electronics" },
                { "key": "minPrice", "value": "100" },
                { "key": "sort", "value": "price-asc" }
              ]
            }
          }
        },
        {
          "name": "Product Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/products/x-phone-pro-max",
              "host": ["{{BASE_URL}}"],
              "path": ["products", "x-phone-pro-max"]
            }
          }
        }
      ]
    },
    {
      "name": "Cart & Checkout",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/cart",
              "host": ["{{BASE_URL}}"],
              "path": ["cart"]
            }
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"replace_with_product_id\",\n  \"variantSku\": \"XP-PRO-128B\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/cart",
              "host": ["{{BASE_URL}}"],
              "path": ["cart"]
            }
          }
        },
        {
          "name": "Place Order (COD/Stripe)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartItems\": [\n    {\n      \"product\": \"replace_with_product_id\",\n      \"name\": \"X-Phone Pro Max\",\n      \"quantity\": 1,\n      \"variantSku\": \"XP-PRO-128B\"\n    }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"123 Luxury Lane\",\n    \"city\": \"Beverly Hills\",\n    \"state\": \"CA\",\n    \"postalCode\": \"90210\",\n    \"country\": \"USA\",\n    \"phone\": \"+15550199\"\n  },\n  \"paymentMethod\": \"cod\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/orders",
              "host": ["{{BASE_URL}}"],
              "path": ["orders"]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    }
  ]
}
